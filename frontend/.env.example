# Backend URL (optional — auto-detected from hostname if unset)
# NEXT_PUBLIC_BACKEND_URL=https://app.pokytalk.com

# ---------------------------------------------------------------------------
# TURN server (REQUIRED for reliable calling)
# ---------------------------------------------------------------------------
# STUN alone connects ~70-80% of peers. Users behind symmetric NAT or on
# mobile carriers REQUIRE a TURN relay or their call silently fails.
# The old public openrelay.metered.ca relay is defunct — plug in a live one.
#
# Options:
#   - Cloudflare Calls TURN (generous free tier)
#   - metered.ca (paid)
#   - Twilio Network Traversal Service
#   - self-hosted coturn on a small VPS
#
# Comma-separated list of TURN URLs. Include a TCP/443 entry for restrictive
# firewalls, e.g.:
#   turn:your.turn.host:3478,turn:your.turn.host:443?transport=tcp
NEXT_PUBLIC_TURN_URLS=
NEXT_PUBLIC_TURN_USERNAME=
NEXT_PUBLIC_TURN_CREDENTIAL=
